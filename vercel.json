{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_APP_URL": "@mergeforge-app-url"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_SUPABASE_URL": "@mergeforge-supabase-url",
      "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@mergeforge-supabase-anon-key"
    }
  }
}
